<?xml version="1.0" encoding="utf-8"?>
<!--
   Companion to backup_rules.xml for Android 12+. Auto-backup is disabled; we manage
   backups manually (see Phase 6.4).
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
    </device-transfer>
</data-extraction-rules>
